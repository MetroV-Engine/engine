{
  "name": "repository-template",
  "private": true,
  "scripts": {
    "prepare": "husky || true",
    "postinstall": "[ -z \"$CI\" ] && [ ! -f .setup-done ] && bash ./.setup/onboard.sh && touch .setup-done || true",
    "helpme": "bash ./scripts/helpme.sh",
    "checkout": "bash ./scripts/branch/create.sh",
    "commit": "bash ./scripts/commit/create.sh",
    "release": "bash ./scripts/release/create.sh",
    "pr": "bash ./scripts/pr/create.sh",
    "merge": "bash ./scripts/pr/merge.sh"
  },
  "packageManager": "pnpm@10.29.3+sha512.498e1fb4cca5aa06c1dcf2611e6fafc50972ffe7189998c409e90de74566444298ffe43e6cd2acdc775ba1aa7cc5e092a8b7054c811ba8c5770f84693d33d2dc",
  "devDependencies": {
    "@changesets/cli": "^2.29.8",
    "husky": "^9.1.7"
  }
}
